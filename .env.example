# VENDR: public, build-time configuration.
# Copy to `.env` for local dev. These are baked into the static build.
# All PUBLIC_ values are safe to expose (the Supabase key is publishable; RLS
# protects the data). Sensible defaults live in vite.config.js, so a plain
# `npm run dev` works without this file.

# Site mode feature flag: coming_soon | maintenance | live
# Unset → defaults to coming_soon. In production the deploy overrides this with
# site_config.site_mode from Supabase (set via the admin panel).
PUBLIC_SITE_MODE=coming_soon

# Supabase (publishable key, safe in the client)
PUBLIC_SUPABASE_URL=https://fmmvqlqdhytcxeucdfbj.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_rpmSPCHja3L2Uy2_RrxjAA_Cz_NyHB2

# Cloudflare Turnstile site key (public, safe in the client). Spam gate on the
# coming-soon email form. The matching SECRET key is NOT here; it is set as a
# Supabase edge-function secret (TURNSTILE_SECRET_KEY) and read server-side only.
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADrAgdwjUX9NIVP3
